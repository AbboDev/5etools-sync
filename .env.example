# ── Google Drive ──────────────────────────────────────────────────────────────
# Chrome App client (used by chrome.identity.getAuthToken on Chrome MV3)
# Application type: "Chrome App" in Google Cloud Console
VITE_GOOGLE_CLIENT_ID_CHROME=YOUR_CHROME_APP_CLIENT_ID.apps.googleusercontent.com

# Web Application client (used by launchWebAuthFlow on Firefox + other browsers)
# Application type: "Web application" in Google Cloud Console
# Authorized redirect URI to add: the URL printed by browser.identity.getRedirectURL('oauth2')
#   On Firefox it looks like: https://EXTENSION_ID.extensions.allizom.org/
VITE_GOOGLE_CLIENT_ID_WEB=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com

# ── Dropbox (stub — implement when ready) ─────────────────────────────────────
VITE_DROPBOX_CLIENT_ID=YOUR_DROPBOX_APP_KEY

# ── OneDrive (stub — implement when ready) ────────────────────────────────────
VITE_ONEDRIVE_CLIENT_ID=YOUR_AZURE_APP_CLIENT_ID
